                        info="hybrid=그래프+벡터(권장)",
                    )
                    qa_refresh = gr.Button("↻ 목록 갱신", scale=1)

                chatbot = gr.Chatbot(
                    label="대화",
                    type="messages",
                    height=440,
                    show_copy_button=True,
                )
                with gr.Row():
                    question_box = gr.Textbox(
                        label="질문",
                        placeholder="질문을 입력하고 Enter (Shift+Enter 줄바꿈)",
                        lines=2,
                        scale=5,
                    )
                    ask_btn = gr.Button("전송 ▶", variant="primary", scale=1)
                clear_btn = gr.Button("대화 초기화")

            # ════════════ TAB 3: 설정 ════════════
            with gr.Tab("⚙ 설정"):
                gr.Markdown("### Ollama 연결")
                with gr.Row():
                    set_url = gr.Textbox(
                        label="Ollama URL",
                        value=cfg["ollama_base_url"], scale=3)
                    test_btn = gr.Button("연결 테스트", scale=1)
                test_status = gr.Markdown("")

                gr.Markdown("### 모델 선택")
                fetch_btn = gr.Button("↻ Ollama 모델 목록 가져오기")
                _models = fetch_ollama_models(cfg["ollama_base_url"])
                with gr.Row():
                    set_llm = gr.Dropdown(
                        label="LLM (텍스트)", allow_custom_value=True,
                        choices=_models or [cfg["llm_model"]], value=cfg["llm_model"])
                    set_vlm = gr.Dropdown(
                        label="VLM (이미지)", allow_custom_value=True,
                        choices=_models or [cfg["vlm_model"]], value=cfg["vlm_model"])
                    set_embed = gr.Dropdown(
                        label="임베딩", allow_custom_value=True,
                        choices=_models or [cfg["embedding_model"]], value=cfg["embedding_model"])

                gr.Markdown("### 임베딩 / 파서 설정")
                with gr.Row():
                    set_dim = gr.Number(
                        label="임베딩 차원", value=cfg["embedding_dim"], precision=0,
                        info="nomic=768, mxbai=1024, bge-m3=1024")
                    set_ctx = gr.Number(
                        label="컨텍스트 크기 (num_ctx)", value=cfg["num_ctx"], precision=0,
                        info="최소 32768 권장")
                    set_parser = gr.Dropdown(
                        label="문서 파서",
                        choices=["docling", "mineru", "paddleocr"],
                        value=cfg["parser"],
                        info="docling=Office, mineru=PDF/OCR")

                save_btn = gr.Button("설정 저장", variant="primary")
                save_status = gr.Markdown("")

            # ════════════ TAB 4: 설치 가이드 ════════════
            with gr.Tab("📖 설치 가이드"):
                gr.Markdown(INSTALL_GUIDE_MD)

        # ──────────────── 이벤트 연결 ────────────────
        # RAG 관리
        create_btn.click(
            create_rag,
            inputs=[new_name, new_desc],
            outputs=[manage_dropdown, manage_status, qa_dropdown, rag_table],
        )
        delete_btn.click(
            delete_rag,
            inputs=[manage_dropdown],
            outputs=[manage_dropdown, manage_status, qa_dropdown, rag_table],
        )
        preview_btn.click(
            preview_folder,
            inputs=[folder_img, folder_pdf, folder_doc],
            outputs=[preview_md, files_state],
        )
        index_btn.click(
            run_indexing,
            inputs=[manage_dropdown, folder_img, folder_pdf, folder_doc, cfg_state],
            outputs=[index_log],
        ).then(
            lambda: registry_to_table(), outputs=[rag_table]
        )

        # Q&A
        ask_btn.click(
            answer_question,
            inputs=[question_box, qa_dropdown, qa_mode, chatbot, cfg_state],
            outputs=[chatbot, question_box],
        )
        question_box.submit(
            answer_question,
            inputs=[question_box, qa_dropdown, qa_mode, chatbot, cfg_state],
            outputs=[chatbot, question_box],
        )
        clear_btn.click(lambda: [], outputs=[chatbot])
        qa_refresh.click(
            lambda: gr.update(choices=get_rag_choices()),
            outputs=[qa_dropdown],
        )

        # 설정
        test_btn.click(lambda u: test_ollama(u), inputs=[set_url], outputs=[test_status])
        fetch_btn.click(
            refresh_models,
            inputs=[set_url],
            outputs=[set_llm, set_vlm, set_embed, save_status],
        )
        save_btn.click(
            save_settings,
            inputs=[set_url, set_llm, set_vlm, set_embed,
                    set_dim, set_ctx, set_parser, cfg_state],
            outputs=[cfg_state, save_status],
        )

    return demo


