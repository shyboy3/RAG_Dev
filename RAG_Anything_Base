    def _refresh_rag_list(self):
        self.rag_list.clear()
        for name, info in self.registry.items():
            item = QListWidgetItem(f"  {name}")
            item.setData(Qt.ItemDataRole.UserRole, name)
            item.setToolTip(info.get("description", ""))
            self.rag_list.addItem(item)
        self.rag_list_changed.emit()

    def _on_rag_selected(self, item):
        if not item:
            self.current_rag = None
            return
        name = item.data(Qt.ItemDataRole.UserRole)
        self.current_rag = name
        info = self.registry.get(name, {})
        desc = info.get("description", "설명 없음")
        fc = info.get("file_count", 0)
        created = info.get("created_at", "")[:10]
        self.rag_info_label.setText(
            f"<b style='color:{ACCENT};font-size:15px'>{name}</b>"
            f"  <span style='color:{TEXT_SECONDARY}'>| {desc} | 파일 {fc}개 | {created}</span>"
        )
        for btn in [self.btn_add_images, self.btn_add_pdfs, self.btn_add_docs,
                    self.clear_files_btn]:
            btn.setEnabled(True)
        self._update_index_btn()

    def _create_new_rag(self):
        dlg = NewRAGDialog(self)
        if dlg.exec() == QDialog.DialogCode.Accepted:
            name, path, desc = dlg.get_values()
            if name in self.registry:
                QMessageBox.warning(self, "중복", f"'{name}' 이름이 이미 존재합니다.")
                return
            Path(path).mkdir(parents=True, exist_ok=True)
            self.registry[name] = {
                "working_dir": path,
                "description": desc,
                "created_at": datetime.now().isoformat(),
                "file_count": 0,
            }
            save_rag_registry(self.registry)
            self._refresh_rag_list()
            # 방금 만든 항목 선택
            for i in range(self.rag_list.count()):
                if self.rag_list.item(i).data(Qt.ItemDataRole.UserRole) == name:
                    self.rag_list.setCurrentRow(i)
                    break

    def _delete_rag(self):
        if not self.current_rag:
            return
        ans = QMessageBox.question(
            self, "삭제 확인",
            f"'{self.current_rag}' RAG를 목록에서 제거합니다.\n(실제 파일은 삭제되지 않습니다)",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No
        )
        if ans == QMessageBox.StandardButton.Yes:
            del self.registry[self.current_rag]
            save_rag_registry(self.registry)
            self.current_rag = None
            self.pending_files.clear()
            self.file_list_widget.clear()
            self._update_file_count()
            self._refresh_rag_list()
            self.rag_info_label.setText("← RAG 시스템을 선택하거나 새로 만드세요")

    def _add_folder(self, ftype: str):
        folder = QFileDialog.getExistingDirectory(self, "폴더 선택")
        if not folder:
            return

        exts_map = {
            "image": {".jpg", ".jpeg", ".png", ".bmp", ".tiff", ".tif", ".webp", ".gif"},
            "pdf":   {".pdf"},
            "doc":   {".ppt", ".pptx", ".csv", ".xlsx", ".xls", ".txt", ".md", ".json"},
        }
        exts = exts_map[ftype]
        found = []
        for p in Path(folder).rglob("*"):
            if p.is_file() and p.suffix.lower() in exts:
                found.append(str(p))

        added = 0
        existing = set(self.pending_files)
        for f in found:
            if f not in existing:
                self.pending_files.append(f)
                self.file_list_widget.addItem(Path(f).name)
                added += 1

        self._update_file_count()
        self._update_index_btn()
        self._log(f"폴더 스캔: {added}개 추가 ({folder})")

    def _clear_files(self):
        self.pending_files.clear()
        self.file_list_widget.clear()
        self._update_file_count()
        self._update_index_btn()

    def _update_file_count(self):
        n = len(self.pending_files)
        self.file_count_label.setText(f"{n}개 파일 선택됨")

    def _update_index_btn(self):
        ok = bool(self.current_rag and self.pending_files)
        self.index_btn.setEnabled(ok and self.index_worker is None)

    def _start_indexing(self):
        if not self.current_rag or not self.pending_files:
            return
        cfg = self.cfg_getter()
        working_dir = self.registry[self.current_rag]["working_dir"]

        self.index_btn.setEnabled(False)
        self.progress_bar.setVisible(True)
        self.progress_bar.setValue(0)

        self.index_worker = IndexWorker(
            self.current_rag, working_dir, list(self.pending_files), cfg
        )
        self.index_worker.progress.connect(self._on_progress)
        self.index_worker.log.connect(self._log)
        self.index_worker.finished.connect(self._on_index_done)
        self.index_worker.start()

    def _on_progress(self, pct, msg):
        self.progress_bar.setValue(pct)
        self.progress_label.setText(msg)

    def _log(self, msg):
        self.log_text.append(msg)
        self.log_text.moveCursor(QTextCursor.MoveOperation.End)

    def _on_index_done(self, success, msg):
        self.index_worker = None
        self.progress_bar.setVisible(False)
        self.progress_label.setText("")
        if success:
            # 파일 수 업데이트
            self.registry[self.current_rag]["file_count"] = (
                self.registry[self.current_rag].get("file_count", 0) + len(self.pending_files)
            )
            save_rag_registry(self.registry)
            self._refresh_rag_list()
            self.pending_files.clear()
            self.file_list_widget.clear()
            self._update_file_count()
            self._log(f"✅ {msg}")
            QMessageBox.information(self, "완료", msg)
        else:
            self._log(f"❌ 오류: {msg}")
            QMessageBox.critical(self, "오류", msg)
        self._update_index_btn()

    def get_rag_list(self):
        return list(self.registry.keys())

    def get_working_dir(self, name):
        return self.registry.get(name, {}).get("working_dir", "")


