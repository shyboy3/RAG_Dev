        history_label.setObjectName("section_title")
        root.addWidget(history_label)

        self.history_text = QTextEdit()
        self.history_text.setReadOnly(True)
        self.history_text.setFont(QFont("Segoe UI", 12))
        root.addWidget(self.history_text, 1)

        # 입력 영역
        sep2 = QFrame(); sep2.setObjectName("separator"); root.addWidget(sep2)

        input_row = QHBoxLayout()
        self.question_edit = QTextEdit()
        self.question_edit.setPlaceholderText("질문을 입력하세요... (Ctrl+Enter로 전송)")
        self.question_edit.setMaximumHeight(90)
        self.question_edit.setFont(QFont("Segoe UI", 12))
        input_row.addWidget(self.question_edit)

        btn_col = QVBoxLayout()
        self.ask_btn = QPushButton("전송\n▶")
        self.ask_btn.setObjectName("primary")
        self.ask_btn.setMinimumSize(70, 60)
        self.ask_btn.clicked.connect(self._ask)
        self.clear_btn = QPushButton("초기화")
        self.clear_btn.setFixedHeight(28)
        self.clear_btn.clicked.connect(self._clear_history)
        btn_col.addWidget(self.ask_btn)
        btn_col.addWidget(self.clear_btn)
        input_row.addLayout(btn_col)
        root.addLayout(input_row)

        # 상태 레이블
        self.status_label = QLabel("")
        self.status_label.setStyleSheet(f"color: {TEXT_SECONDARY}; font-size: 12px;")
        root.addWidget(self.status_label)

        # Ctrl+Enter 단축키
        from PyQt6.QtGui import QKeySequence
        from PyQt6.QtWidgets import QShortcut
        shortcut = QShortcut(QKeySequence("Ctrl+Return"), self.question_edit)
        shortcut.activated.connect(self._ask)

    def refresh_rag_list(self):
        current = self.rag_combo.currentText()
        self.rag_combo.clear()
        rags = self.rag_manage_tab.get_rag_list()
        self.rag_combo.addItems(rags)
        if current in rags:
            self.rag_combo.setCurrentText(current)

    def _ask(self):
        question = self.question_edit.toPlainText().strip()
        if not question:
            return
        rag_name = self.rag_combo.currentText()
        if not rag_name:
            QMessageBox.warning(self, "RAG 없음", "사용할 RAG를 선택하세요.")
            return
        working_dir = self.rag_manage_tab.get_working_dir(rag_name)
        if not working_dir:
            return

        cfg = self.cfg_getter()
        cfg["query_mode"] = self.mode_combo.currentText()

        self.ask_btn.setEnabled(False)
        self.status_label.setText("⏳ 답변 생성 중...")
        self._append_history("user", question)
        self.question_edit.clear()

        self.query_worker = QueryWorker(working_dir, question, cfg)
        self.query_worker.result.connect(self._on_answer)
        self.query_worker.error.connect(self._on_error)
        self.query_worker.start()

    def _on_answer(self, answer):
        self._append_history("assistant", answer)
        self.status_label.setText(f"✅ 답변 완료 [{self.rag_combo.currentText()}]")
        self.ask_btn.setEnabled(True)
        self.query_worker = None

    def _on_error(self, msg):
        self._append_history("error", msg)
        self.status_label.setText("❌ 오류 발생")
        self.ask_btn.setEnabled(True)
        self.query_worker = None

    def _append_history(self, role: str, text: str):
        cursor = self.history_text.textCursor()
        cursor.movePosition(QTextCursor.MoveOperation.End)
        self.history_text.setTextCursor(cursor)

        if role == "user":
            self.history_text.append(
                f"<div style='margin:12px 0 4px 0;'>"
                f"<span style='color:{ACCENT};font-weight:700;'>▶ 질문</span>"
                f"<br><span style='color:{TEXT_PRIMARY};'>{text}</span></div>"
            )
        elif role == "assistant":
            self.history_text.append(
                f"<div style='background:{CARD_BG};border-left:3px solid {SUCCESS};"
                f"padding:10px 14px;margin:4px 0 16px 0;border-radius:4px;'>"
                f"<span style='color:{SUCCESS};font-weight:700;'>● 답변</span>"
                f"<br><span style='color:{TEXT_PRIMARY};white-space:pre-wrap;'>{text}</span></div>"
            )
        else:
            self.history_text.append(
                f"<div style='color:{ERROR};margin:8px 0;'>⚠ {text}</div>"
            )
        self.history_text.moveCursor(QTextCursor.MoveOperation.End)

    def _clear_history(self):
        self.history_text.clear()
        self.history = []


