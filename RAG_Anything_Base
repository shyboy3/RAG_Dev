class IndexWorker(QThread):
    """RAG 인덱싱 작업을 백그라운드에서 실행"""
    progress = pyqtSignal(int, str)      # (percent, message)
    finished = pyqtSignal(bool, str)     # (success, message)
    log = pyqtSignal(str)

    def __init__(self, rag_name: str, working_dir: str, file_list: list,
                 cfg: dict, parent=None):
        super().__init__(parent)
        self.rag_name = rag_name
        self.working_dir = working_dir
        self.file_list = file_list
        self.cfg = cfg

    def run(self):
        try:
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            loop.run_until_complete(self._index_async())
        except Exception as e:
            self.finished.emit(False, str(e))

    async def _index_async(self):
        try:
            from raganything import RAGAnything, RAGAnythingConfig
            from lightrag.llm.ollama import ollama_complete_if_cache, ollama_embed
            from lightrag.utils import EmbeddingFunc
            import base64

            cfg = self.cfg
            base_url = cfg["ollama_base_url"]
            llm_model = cfg["llm_model"]
            vlm_model = cfg["vlm_model"]
            embed_model = cfg["embedding_model"]
            embed_dim = int(cfg["embedding_dim"])
            num_ctx = int(cfg["num_ctx"])
            parser = cfg.get("parser", "docling")

            self.log.emit(f"[{datetime.now().strftime('%H:%M:%S')}] RAG 초기화 중...")
            self.progress.emit(5, "RAG 엔진 초기화...")

            config = RAGAnythingConfig(
                working_dir=self.working_dir,
                parser=parser,
                parse_method="auto",
                enable_image_processing=True,
                enable_table_processing=True,
                enable_equation_processing=True,
            )

            def llm_func(prompt, system_prompt=None, history_messages=[], **kwargs):
                return ollama_complete_if_cache(
                    llm_model, prompt,
                    system_prompt=system_prompt,
                    history_messages=history_messages,
                    base_url=base_url,
                    options={"num_ctx": num_ctx},
                    **kwargs,
                )

            def encode_b64(path):
                with open(path, "rb") as f:
                    return base64.b64encode(f.read()).decode("utf-8")

            def vision_func(prompt, system_prompt=None, history_messages=[],
                            image_data=None, messages=None, **kwargs):
                if messages:
                    return ollama_complete_if_cache(
                        vlm_model, "",
                        system_prompt=None, history_messages=[],
                        messages=messages, base_url=base_url, **kwargs)
                elif image_data:
                    msg_list = []
                    if system_prompt:
                        msg_list.append({"role": "system", "content": system_prompt})
                    msg_list.append({
                        "role": "user",
                        "content": [
                            {"type": "text", "text": prompt},
                            {"type": "image_url",
                             "image_url": {"url": f"data:image/jpeg;base64,{image_data}"}}
                        ]
                    })
                    return ollama_complete_if_cache(
                        vlm_model, "",
                        system_prompt=None, history_messages=[],
                        messages=msg_list, base_url=base_url, **kwargs)
                else:
                    return llm_func(prompt, system_prompt, history_messages, **kwargs)

            embed_func = EmbeddingFunc(
                embedding_dim=embed_dim,
                max_token_size=8192,
                func=lambda texts: ollama_embed(
                    texts, embed_model=embed_model, base_url=base_url
                ),
            )

            rag = RAGAnything(
                config=config,
                llm_model_func=llm_func,
                vision_model_func=vision_func,
                embedding_func=embed_func,
            )

            total = len(self.file_list)
            self.log.emit(f"[{datetime.now().strftime('%H:%M:%S')}] 총 {total}개 파일 처리 시작")

            for i, fpath in enumerate(self.file_list, 1):
                pct = 10 + int(85 * i / total)
                fname = Path(fpath).name
                self.progress.emit(pct, f"처리 중: {fname} ({i}/{total})")
                self.log.emit(f"[{datetime.now().strftime('%H:%M:%S')}] [{i}/{total}] {fname}")
                try:
                    output_dir = str(Path(self.working_dir) / "parsed_output")
                    await rag.process_document_complete(
                        file_path=fpath,
                        output_dir=output_dir,
                        parse_method="auto",
                    )
                except Exception as e:
                    self.log.emit(f"  ⚠ 오류 건너뜀: {e}")

            self.progress.emit(100, "완료!")
            self.log.emit(f"[{datetime.now().strftime('%H:%M:%S')}] ✅ 인덱싱 완료 ({total}개 파일)")
            self.finished.emit(True, f"{total}개 파일 인덱싱 완료")

        except ImportError as e:
            self.finished.emit(False, f"패키지 미설치: {e}\n설치 가이드 탭을 확인하세요.")
        except Exception as e:
            self.finished.emit(False, str(e))


class QueryWorker(QThread):
    """RAG Q&A 쿼리를 백그라운드에서 실행"""
    result = pyqtSignal(str)
    error = pyqtSignal(str)

    def __init__(self, working_dir: str, question: str, cfg: dict, parent=None):
        super().__init__(parent)
        self.working_dir = working_dir
        self.question = question
        self.cfg = cfg

    def run(self):
        try:
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            answer = loop.run_until_complete(self._query_async())
            self.result.emit(answer)
        except Exception as e:
            self.error.emit(str(e))

    async def _query_async(self):
        from raganything import RAGAnything, RAGAnythingConfig
        from lightrag.llm.ollama import ollama_complete_if_cache, ollama_embed
        from lightrag.utils import EmbeddingFunc

        cfg = self.cfg
        base_url = cfg["ollama_base_url"]
        llm_model = cfg["llm_model"]
        vlm_model = cfg["vlm_model"]
        embed_model = cfg["embedding_model"]
        embed_dim = int(cfg["embedding_dim"])
        num_ctx = int(cfg["num_ctx"])
        mode = cfg.get("query_mode", "hybrid")

        config = RAGAnythingConfig(
            working_dir=self.working_dir,
            parser=cfg.get("parser", "docling"),
        )

        def llm_func(prompt, system_prompt=None, history_messages=[], **kwargs):
            return ollama_complete_if_cache(
                llm_model, prompt,
                system_prompt=system_prompt,
                history_messages=history_messages,
                base_url=base_url,
                options={"num_ctx": num_ctx},
                **kwargs,
            )

        def vision_func(prompt, system_prompt=None, history_messages=[],
                        image_data=None, messages=None, **kwargs):
            if messages:
                return ollama_complete_if_cache(
                    vlm_model, "", system_prompt=None, history_messages=[],
                    messages=messages, base_url=base_url, **kwargs)
            return llm_func(prompt, system_prompt, history_messages, **kwargs)

        embed_func = EmbeddingFunc(
            embedding_dim=embed_dim,
            max_token_size=8192,
            func=lambda texts: ollama_embed(
                texts, embed_model=embed_model, base_url=base_url
            ),
        )

        rag = RAGAnything(
            config=config,
            llm_model_func=llm_func,
            vision_model_func=vision_func,
            embedding_func=embed_func,
        )

        answer = await rag.aquery(self.question, mode=mode)
        return answer


class OllamaModelsWorker(QThread):
    """Ollama 모델 목록 조회"""
    result = pyqtSignal(list)
    error = pyqtSignal(str)

    def __init__(self, base_url: str, parent=None):
        super().__init__(parent)
        self.base_url = base_url

    def run(self):
        try:
            import urllib.request
            import json
            url = self.base_url.rstrip("/") + "/api/tags"
            with urllib.request.urlopen(url, timeout=5) as resp:
                data = json.loads(resp.read())
            models = [m["name"] for m in data.get("models", [])]
            self.result.emit(models)
        except Exception as e:
            self.error.emit(str(e))


