# ──────────────────────────────────────────────────────────────────────────────
#  Gradio 버전 호환 감지
#  일부 환경에서 gradio 버전 표기는 6.x여도 Chatbot이 type 인자를 받지 못함
#  (gradio_pdf 등 커스텀 컴포넌트 충돌). 런타임에 실제 시그니처로 판별.
# ──────────────────────────────────────────────────────────────────────────────
try:
    _CHATBOT_PARAMS = inspect.signature(gr.Chatbot.__init__).parameters
    SUPPORTS_MESSAGES = "type" in _CHATBOT_PARAMS
except Exception:
    SUPPORTS_MESSAGES = False


def make_chatbot(**kwargs):
    """Chatbot 생성 — messages(dict) 형식 우선 시도.
    type 인자를 받는 버전이면 messages 형식, 아니면 기본 형식."""
    try:
        return gr.Chatbot(type="messages", **kwargs)
    except (TypeError, Exception):
        kwargs.pop("type", None)
        return gr.Chatbot(**kwargs)


def to_history_append(history, user_msg, assistant_msg):
    """messages(dict) 형식으로 (질문, 답변) 한 쌍을 history에 추가.
    Gradio 6.x는 dict 형식을 기대하므로 항상 dict로 통일."""
    history = history or []
    history.append({"role": "user", "content": str(user_msg)})
    history.append({"role": "assistant", "content": str(assistant_msg)})
    return history


