#  Ollama 헬퍼
# ──────────────────────────────────────────────────────────────────────────────
def fetch_ollama_models(base_url: str) -> list:
    try:
        url = base_url.rstrip("/") + "/api/tags"
        with urllib.request.urlopen(url, timeout=5) as resp:
            data = json.loads(resp.read())
        return [m["name"] for m in data.get("models", [])]
    except Exception:
        return []


def test_ollama(base_url: str) -> str:
    try:
        url = base_url.rstrip("/") + "/api/tags"
        with urllib.request.urlopen(url, timeout=4) as resp:
            data = json.loads(resp.read())
        n = len(data.get("models", []))
        return f"✅ 연결 성공 — 설치된 모델 {n}개"
    except Exception as e:
        return f"❌ 연결 실패: {e}"


# ──────────────────────────────────────────────────────────────────────────────
#  RAG-Anything 인스턴스 빌더 (인덱싱/쿼리 공용)
# ──────────────────────────────────────────────────────────────────────────────
def build_rag_instance(working_dir: str, cfg: dict):
    """RAGAnything 인스턴스 생성 — 공식 README 패턴 그대로.

    핵심 (공식 문서 확인):
      - RAGAnything(working_dir=, llm_model_func=, vision_model_func=, embedding_func=)
        → config 객체 없이 직접 인자 전달
      - llm_model_func 는 lambda 래퍼로 감싸고 **kwargs 그대로 전달
      - ollama_model_complete 는 model 인자를 첫 인자 다음에 받지 않고,
        kwargs로 받음 → lambda 안에서 직접 호출
    """
    from raganything import RAGAnything
    from lightrag.llm.ollama import ollama_model_complete, ollama_embed
    from lightrag.utils import EmbeddingFunc

    base_url    = cfg["ollama_base_url"]
    llm_model   = cfg["llm_model"]
    vlm_model   = cfg["vlm_model"]
    embed_model = cfg["embedding_model"]
    embed_dim   = int(cfg["embedding_dim"])
    num_ctx     = int(cfg["num_ctx"])

    # ── LLM 함수 (공식 lambda 래퍼 패턴) ──────────────────────────
    def llm_model_func(prompt, system_prompt=None, history_messages=[], **kwargs):
        return ollama_model_complete(
            prompt,
            system_prompt=system_prompt,
            history_messages=history_messages,
            host=base_url,
            **kwargs,
        )

    # ── VLM 함수 (이미지 처리) ────────────────────────────────────
    def vision_model_func(prompt, system_prompt=None, history_messages=[],
                          image_data=None, messages=None, **kwargs):
        if messages:
            return ollama_model_complete(
                "",
                system_prompt=None,
                history_messages=[],
                messages=messages,
                host=base_url,
                **kwargs,
            )
        elif image_data:
            msg = []
            if system_prompt:
                msg.append({"role": "system", "content": system_prompt})
            msg.append({
                "role": "user",
                "content": [
                    {"type": "text", "text": prompt},
                    {"type": "image_url",
                     "image_url": {
                         "url": f"data:image/jpeg;base64,{image_data}"
                     }},
                ],
            })
            return ollama_model_complete(
                "",
                system_prompt=None,
                history_messages=[],
                messages=msg,
                host=base_url,
                **kwargs,
            )
        else:
            return llm_model_func(prompt, system_prompt,
                                  history_messages, **kwargs)

    # ── 임베딩 함수 ───────────────────────────────────────────────
    embedding_func = EmbeddingFunc(
        embedding_dim=embed_dim,
        max_token_size=8192,
        func=lambda texts: ollama_embed(
            texts,
            embed_model=embed_model,
            host=base_url,
        ),
    )

    # ── RAGAnythingConfig (working_dir는 여기에) ──────────────────
    from raganything import RAGAnythingConfig
    config = RAGAnythingConfig(
        working_dir=working_dir,
        parser=cfg.get("parser", "docling"),
        parse_method="auto",
        enable_image_processing=True,
        enable_table_processing=True,
        enable_equation_processing=True,
    )

    # ── RAGAnything (실제 시그니처: config + func들) ──────────────
    rag = RAGAnything(
        config=config,
        llm_model_func=llm_model_func,
        vision_model_func=vision_model_func,
        embedding_func=embedding_func,
        lightrag_kwargs={
            "llm_model_name": llm_model,
            "llm_model_kwargs": {
                "host": base_url,
                "options": {"num_ctx": num_ctx},
            },
        },
    )
    return rag


def scan_folder(folder: str, ftype: str) -> list:
    if not folder or not Path(folder).is_dir():
        return []
    exts = {"image": IMAGE_EXTS, "pdf": PDF_EXTS, "doc": DOC_EXTS}.get(ftype, ALL_EXTS)
    return [str(p) for p in Path(folder).rglob("*")
            if p.is_file() and p.suffix.lower() in exts]


