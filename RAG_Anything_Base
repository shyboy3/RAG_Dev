APP_DIR = Path.home() / ".rag_studio"
CONFIG_FILE = APP_DIR / "config.json"
RAG_REGISTRY_FILE = APP_DIR / "rag_registry.json"
RAG_DATA_DIR = APP_DIR / "rag_data"

IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".bmp", ".tiff", ".tif", ".webp", ".gif"}
PDF_EXTS = {".pdf"}
DOC_EXTS = {".ppt", ".pptx", ".csv", ".xlsx", ".xls", ".txt", ".md", ".json"}
ALL_EXTS = IMAGE_EXTS | PDF_EXTS | DOC_EXTS

DEFAULT_CONFIG = {
    "ollama_base_url": "http://localhost:11434",
    "llm_model": "llama3.2",
    "vlm_model": "llama3.2-vision",
    "embedding_model": "nomic-embed-text",
    "embedding_dim": 768,
    "num_ctx": 32768,
    "parser": "docling",
    "query_mode": "hybrid",
}


def ensure_dirs():
    APP_DIR.mkdir(parents=True, exist_ok=True)
    RAG_DATA_DIR.mkdir(parents=True, exist_ok=True)


def load_config() -> dict:
    ensure_dirs()
    cfg = dict(DEFAULT_CONFIG)
    if CONFIG_FILE.exists():
        try:
            cfg.update(json.loads(CONFIG_FILE.read_text(encoding="utf-8")))
        except Exception:
            pass
    return cfg


def save_config(cfg: dict):
    ensure_dirs()
    CONFIG_FILE.write_text(json.dumps(cfg, ensure_ascii=False, indent=2), encoding="utf-8")


def load_registry() -> dict:
    ensure_dirs()
    if RAG_REGISTRY_FILE.exists():
        try:
            return json.loads(RAG_REGISTRY_FILE.read_text(encoding="utf-8"))
        except Exception:
            pass
    return {}


def save_registry(reg: dict):
    ensure_dirs()
    RAG_REGISTRY_FILE.write_text(json.dumps(reg, ensure_ascii=False, indent=2), encoding="utf-8")


def safe_dirname(name: str) -> str:
    s = re.sub(r"[^\w가-힣\-]", "_", name.strip())
    return s or "rag"


# ──────────────────────────────────────────────────────────────────────────────
#  Ollama 헬퍼
# ──────────────────────────────────────────────────────────────────────────────
def fetch_ollama_models(base_url: str) -> list:
    try:
        url = base_url.rstrip("/") + "/api/tags"
        with urllib.request.urlopen(url, timeout=5) as resp:
            data = json.loads(resp.read())
        return [m["name"] for m in data.get("models", [])]
    except Exception:
        return []


def test_ollama(base_url: str) -> str:
    try:
        url = base_url.rstrip("/") + "/api/tags"
        with urllib.request.urlopen(url, timeout=4) as resp:
            data = json.loads(resp.read())
        n = len(data.get("models", []))
        return f"✅ 연결 성공 — 설치된 모델 {n}개"
    except Exception as e:
        return f"❌ 연결 실패: {e}"


# ──────────────────────────────────────────────────────────────────────────────
#  RAG-Anything 인스턴스 빌더 (인덱싱/쿼리 공용)
# ──────────────────────────────────────────────────────────────────────────────
def build_rag_instance(working_dir: str, cfg: dict):
    """RAGAnything 인스턴스를 생성해서 반환. import 실패 시 예외 전달."""
    from raganything import RAGAnything, RAGAnythingConfig
    from lightrag.llm.ollama import ollama_complete_if_cache, ollama_embed
    from lightrag.utils import EmbeddingFunc
    import base64

    base_url = cfg["ollama_base_url"]
    llm_model = cfg["llm_model"]
    vlm_model = cfg["vlm_model"]
    embed_model = cfg["embedding_model"]
    embed_dim = int(cfg["embedding_dim"])
    num_ctx = int(cfg["num_ctx"])
    parser = cfg.get("parser", "docling")

    config = RAGAnythingConfig(
        working_dir=working_dir,
        parser=parser,
        parse_method="auto",
        enable_image_processing=True,
        enable_table_processing=True,
        enable_equation_processing=True,
    )

    def llm_func(prompt, system_prompt=None, history_messages=[], **kwargs):
        return ollama_complete_if_cache(
            llm_model, prompt,
            system_prompt=system_prompt,
            history_messages=history_messages,
            base_url=base_url,
            options={"num_ctx": num_ctx},
            **kwargs,
        )

    def vision_func(prompt, system_prompt=None, history_messages=[],
                    image_data=None, messages=None, **kwargs):
        if messages:
            return ollama_complete_if_cache(
                vlm_model, "", system_prompt=None, history_messages=[],
                messages=messages, base_url=base_url, **kwargs)
        elif image_data:
            msg_list = []
            if system_prompt:
                msg_list.append({"role": "system", "content": system_prompt})
            msg_list.append({
                "role": "user",
                "content": [
                    {"type": "text", "text": prompt},
                    {"type": "image_url",
                     "image_url": {"url": f"data:image/jpeg;base64,{image_data}"}},
                ],
            })
            return ollama_complete_if_cache(
                vlm_model, "", system_prompt=None, history_messages=[],
                messages=msg_list, base_url=base_url, **kwargs)
        else:
            return llm_func(prompt, system_prompt, history_messages, **kwargs)

    embed_func = EmbeddingFunc(
        embedding_dim=embed_dim,
        max_token_size=8192,
        func=lambda texts: ollama_embed(texts, embed_model=embed_model, base_url=base_url),
    )

    rag = RAGAnything(
        config=config,
        llm_model_func=llm_func,
        vision_model_func=vision_func,
        embedding_func=embed_func,
    )
    return rag


# ──────────────────────────────────────────────────────────────────────────────
#  폴더 스캔
# ──────────────────────────────────────────────────────────────────────────────
def scan_folder(folder: str, ftype: str) -> list:
    if not folder or not Path(folder).is_dir():
        return []
    exts = {"image": IMAGE_EXTS, "pdf": PDF_EXTS, "doc": DOC_EXTS}.get(ftype, ALL_EXTS)
    return [str(p) for p in Path(folder).rglob("*")
            if p.is_file() and p.suffix.lower() in exts]


