                        gallery = gr.Gallery(label="추출 이미지", columns=3, height=360)
                    zip_out = gr.File(label="전체 결과 zip 다운로드")

            run_btn.click(
                run_pipeline,
                inputs=[files, engine, artifacts, do_ocr, gen_images, images_scale,
                        use_gpu, ollama_url, model_name, roundtrip, embed],
                outputs=[log, md_view, gallery, zip_out, sel],
            )
            sel.change(switch_preview, inputs=[sel], outputs=[md_view, gallery])

        with gr.Tab("base64 유틸"):
            gr.Markdown(
                "파일 ↔ base64 라운드트립 (전송/무결성 테스트용)\n\n"
                "> **Notepad++ 스타일**을 켜면 76자마다 줄바꿈(MIME 형식)을 넣어 "
                "Notepad++ MIME Tools 등 다른 도구 출력과 문자열까지 맞춥니다. "
                "줄바꿈은 표현 차이일 뿐 디코딩 결과는 표준과 동일합니다."
            )
            with gr.Row():
                with gr.Column():
                    enc_in = gr.File(label="파일 → base64")
                    with gr.Row():
                        np_style = gr.Checkbox(label="Notepad++ 스타일 (줄바꿈)", value=False)
                        np_wrap = gr.Number(label="줄폭(자)", value=76, precision=0,
                                            minimum=1, scale=0)
                    enc_info = gr.Textbox(label="정보", interactive=False)
                    enc_out = gr.Code(label="base64 (절단 미리보기)")
                    enc_file = gr.File(label=".b64 파일 다운로드 (전체)")
                    enc_in.change(encode_file, inputs=[enc_in, np_style, np_wrap],
                                  outputs=[enc_info, enc_out, enc_file])
                    np_style.change(encode_file, inputs=[enc_in, np_style, np_wrap],
                                    outputs=[enc_info, enc_out, enc_file])
                    np_wrap.change(encode_file, inputs=[enc_in, np_style, np_wrap],
                                   outputs=[enc_info, enc_out, enc_file])
                with gr.Column():
                    dec_in = gr.Textbox(label="base64 → 파일", lines=8,
                                        placeholder="base64 또는 data:...;base64, 붙여넣기 (줄바꿈 있어도 OK)")
                    dec_name = gr.Textbox(label="복원 파일명", value="restored.pdf")
                    dec_btn = gr.Button("복원")
                    dec_info = gr.Textbox(label="결과", interactive=False)
                    dec_file = gr.File(label="복원 파일")
                    dec_btn.click(decode_b64, inputs=[dec_in, dec_name], outputs=[dec_info, dec_file])

        gr.Markdown(
            "---\n"
            "**기본 엔진 모델 준비**: 첫 실행 전 인터넷 PC에서 `docling-tools models download` 로 받아 "
            "폴더째 옮긴 뒤 *artifacts_path* 에 지정. OCR을 켜면 OCR 엔진 모델도 별도 필요.\n\n"
            "**granite-docling 준비**: 인터넷 PC에서 `ollama pull ibm/granite-docling` → "
            "air-gapped 로 모델 옮긴 뒤 Ollama 가동. 엔진을 'granite-docling'으로 고르면 끝 "
            "(artifacts_path·OCR 불필요). 표가 깨지면 기본 엔진으로 폴백하세요."
        )
