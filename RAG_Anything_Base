class RAGStudioWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.cfg = load_config()
        self.setWindowTitle("RAG Studio  —  RAG-Anything 기반 멀티모달 RAG 관리 도구")
        self.setMinimumSize(1100, 780)
        self._build_ui()

    def _build_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        main_layout = QVBoxLayout(central)
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)

        # 헤더
        header = QWidget()
        header.setFixedHeight(54)
        header.setStyleSheet(f"background: {PANEL_BG}; border-bottom: 1px solid {BORDER};")
        hl = QHBoxLayout(header)
        hl.setContentsMargins(20, 0, 20, 0)
        logo = QLabel("◈ RAG Studio")
        logo.setFont(QFont("Segoe UI", 16, QFont.Weight.Bold))
        logo.setStyleSheet(f"color: {ACCENT};")
        subtitle = QLabel("RAG-Anything · Ollama · Multimodal")
        subtitle.setStyleSheet(f"color: {TEXT_MUTED}; font-size: 12px;")
        hl.addWidget(logo)
        hl.addSpacing(12)
        hl.addWidget(subtitle)
        hl.addStretch()
        main_layout.addWidget(header)

        # 탭
        self.tabs = QTabWidget()
        self.tabs.setContentsMargins(8, 8, 8, 8)

        self.settings_tab = SettingsTab(self.cfg)
        self.manage_tab = RAGManageTab(lambda: self.settings_tab.get_cfg())
        self.qa_tab = QATab(
            lambda: self.settings_tab.get_cfg(),
            self.manage_tab
        )
        self.guide_tab = InstallGuideTab()

        self.tabs.addTab(self.manage_tab, "  RAG 관리  ")
        self.tabs.addTab(self.qa_tab,     "  Q & A  ")
        self.tabs.addTab(self.settings_tab, "  설정  ")
        self.tabs.addTab(self.guide_tab,   "  설치 가이드  ")

        # RAG 목록이 변경되면 QA 탭 갱신
        self.manage_tab.rag_list_changed.connect(self.qa_tab.refresh_rag_list)

        # Q&A 탭 진입 시 목록 갱신
        self.tabs.currentChanged.connect(self._on_tab_changed)

        main_layout.addWidget(self.tabs)

    def _on_tab_changed(self, idx):
        if self.tabs.widget(idx) is self.qa_tab:
            self.qa_tab.refresh_rag_list()


# ──────────────────────────────────────────────────────────────────────────────
#  진입점
# ──────────────────────────────────────────────────────────────────────────────
def main():
    app = QApplication(sys.argv)
    app.setApplicationName("RAG Studio")
    app.setStyleSheet(STYLESHEET)

    # 고해상도 디스플레이 지원
    if hasattr(Qt.ApplicationAttribute, 'AA_EnableHighDpiScaling'):
        app.setAttribute(Qt.ApplicationAttribute.AA_EnableHighDpiScaling, True)

    window = RAGStudioWindow()
    window.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
