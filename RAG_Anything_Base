#  비즈니스 로직 (Gradio 콜백)
# ──────────────────────────────────────────────────────────────────────────────
def get_rag_choices() -> list:
    reg = load_registry()
    return list(reg.keys())


def create_rag(name: str, description: str):
    name = (name or "").strip()
    if not name:
        return gr.update(), "⚠ RAG 이름을 입력하세요.", gr.update(), gr.update()
    reg = load_registry()
    if name in reg:
        return gr.update(), f"⚠ '{name}' 이름이 이미 존재합니다.", gr.update(), gr.update()

    working_dir = str(RAG_DATA_DIR / safe_dirname(name))
    Path(working_dir).mkdir(parents=True, exist_ok=True)
    reg[name] = {
        "working_dir": working_dir,
        "description": description.strip(),
        "created_at": datetime.now().isoformat(),
        "file_count": 0,
    }
    save_registry(reg)
    choices = list(reg.keys())
    table = registry_to_table()
    return (
        gr.update(choices=choices, value=name),       # manage dropdown
        f"✅ '{name}' RAG 생성 완료 → {working_dir}",
        gr.update(choices=choices, value=name),       # qa dropdown
        table,
    )


def delete_rag(name: str):
    if not name:
        return gr.update(), "⚠ 삭제할 RAG를 선택하세요.", gr.update(), gr.update()
    reg = load_registry()
    if name in reg:
        del reg[name]
        save_registry(reg)
    choices = list(reg.keys())
    new_val = choices[0] if choices else None
    return (
        gr.update(choices=choices, value=new_val),
        f"🗑 '{name}' 제거됨 (실제 파일은 보존)",
        gr.update(choices=choices, value=new_val),
        registry_to_table(),
    )


def registry_to_table() -> list:
    reg = load_registry()
    rows = []
    for name, info in reg.items():
        rows.append([
            name,
            info.get("description", ""),
            info.get("file_count", 0),
            info.get("created_at", "")[:16].replace("T", " "),
            info.get("working_dir", ""),
        ])
    return rows


def preview_folder(folder_img, folder_pdf, folder_doc):
    """세 폴더를 스캔해서 파일 목록 미리보기"""
    files = []
    files += scan_folder(folder_img, "image")
    files += scan_folder(folder_pdf, "pdf")
    files += scan_folder(folder_doc, "doc")
    files = sorted(set(files))
    if not files:
        return "스캔된 파일이 없습니다. 폴더 경로를 확인하세요.", files
    by_type = {"이미지": 0, "PDF": 0, "문서": 0}
    for f in files:
        ext = Path(f).suffix.lower()
        if ext in IMAGE_EXTS:
            by_type["이미지"] += 1
        elif ext in PDF_EXTS:
            by_type["PDF"] += 1
        else:
            by_type["문서"] += 1
    summary = (f"📊 총 **{len(files)}개** 파일 "
               f"(이미지 {by_type['이미지']}, PDF {by_type['PDF']}, 문서 {by_type['문서']})\n\n")
    preview = "\n".join(f"- {Path(f).name}" for f in files[:30])
    if len(files) > 30:
        preview += f"\n- ... 외 {len(files) - 30}개"
    return summary + preview, files


def run_indexing(rag_name, folder_img, folder_pdf, folder_doc,
                 cfg_state, progress=gr.Progress()):
    """선택한 폴더들을 스캔해 인덱싱 실행 (제너레이터로 로그 스트리밍)"""
    if not rag_name:
        yield "⚠ RAG를 먼저 선택하거나 생성하세요."
        return

    reg = load_registry()
    if rag_name not in reg:
        yield f"⚠ '{rag_name}' RAG를 찾을 수 없습니다."
        return

    files = []
    files += scan_folder(folder_img, "image")
    files += scan_folder(folder_pdf, "pdf")
    files += scan_folder(folder_doc, "doc")
    files = sorted(set(files))

    if not files:
        yield "⚠ 추가할 파일이 없습니다. 폴더 경로를 확인하세요."
        return

    working_dir = reg[rag_name]["working_dir"]
    cfg = cfg_state

    log = [f"[{datetime.now():%H:%M:%S}] '{rag_name}' 인덱싱 시작 — {len(files)}개 파일"]
    yield "\n".join(log)

    try:
        progress(0.05, desc="RAG 엔진 초기화...")
        rag = build_rag_instance(working_dir, cfg)
    except ImportError as e:
        yield (f"❌ 패키지 미설치: {e}\n\n"
               f"설치 가이드 탭을 참고하세요:\n"
               f"  pip install \"raganything[all]\" \"docling[all]\"")
        return
    except Exception as e:
        yield f"❌ 초기화 실패: {e}"
        return

    output_dir = str(Path(working_dir) / "parsed_output")

    async def _process_all():
        total = len(files)
        for i, fpath in enumerate(files, 1):
            fname = Path(fpath).name
            progress(0.1 + 0.85 * i / total, desc=f"{fname} ({i}/{total})")
            log.append(f"[{datetime.now():%H:%M:%S}] [{i}/{total}] {fname}")
            try:
                await rag.process_document_complete(
                    file_path=fpath, output_dir=output_dir, parse_method="auto"
                )
            except Exception as e:
                log.append(f"    ⚠ 건너뜀: {e}")
        return total

    try:
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        total = loop.run_until_complete(_process_all())
        loop.close()
    except Exception as e:
        log.append(f"❌ 인덱싱 중 오류: {e}")
        yield "\n".join(log)
        return

    # 파일 수 갱신
    reg = load_registry()
    reg[rag_name]["file_count"] = reg[rag_name].get("file_count", 0) + total
    save_registry(reg)

    log.append(f"[{datetime.now():%H:%M:%S}] ✅ 완료 — {total}개 파일 인덱싱됨")
    progress(1.0, desc="완료")
    yield "\n".join(log)


def answer_question(question, rag_name, mode, history, cfg_state):
    """Q&A — Chatbot messages 형식 반환 (Gradio 6)"""
    history = history or []
    if not question or not question.strip():
        return history, ""
    if not rag_name:
        history.append({"role": "user", "content": question})
        history.append({"role": "assistant",
                        "content": "⚠ 먼저 사용할 RAG를 선택하세요."})
        return history, ""

    reg = load_registry()
    if rag_name not in reg:
        history.append({"role": "user", "content": question})
        history.append({"role": "assistant",
                        "content": f"⚠ '{rag_name}' RAG를 찾을 수 없습니다."})
        return history, ""

    working_dir = reg[rag_name]["working_dir"]
    cfg = dict(cfg_state)
    cfg["query_mode"] = mode

    history.append({"role": "user", "content": question})

    try:
        rag = build_rag_instance(working_dir, cfg)

        async def _q():
            return await rag.aquery(question, mode=mode)

        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        answer = loop.run_until_complete(_q())
        loop.close()
    except ImportError as e:
        answer = f"❌ 패키지 미설치: {e}"
    except Exception as e:
        answer = f"❌ 오류: {e}"

    history.append({"role": "assistant", "content": str(answer)})
    return history, ""


# ── 설정 콜백 ──
def save_settings(url, llm, vlm, embed, embed_dim, num_ctx, parser, cfg_state):
    cfg = dict(cfg_state)
    cfg.update({
        "ollama_base_url": url.strip(),
        "llm_model": llm.strip(),
        "vlm_model": vlm.strip(),
        "embedding_model": embed.strip(),
        "embedding_dim": int(embed_dim),
        "num_ctx": int(num_ctx),
        "parser": parser,
    })
    save_config(cfg)
    return cfg, "✅ 설정이 저장되었습니다."


def refresh_models(url):
    models = fetch_ollama_models(url.strip())
    if not models:
        return (gr.update(), gr.update(), gr.update(),
                "⚠ 모델을 가져오지 못했습니다. Ollama가 실행 중인지 확인하세요.")
    return (
        gr.update(choices=models),
        gr.update(choices=models),
        gr.update(choices=models),
        f"✅ {len(models)}개 모델을 가져왔습니다.",
    )


