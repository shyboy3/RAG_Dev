#  설정/저장 경로
# ──────────────────────────────────────────────────────────────────────────────
APP_DIR = Path.home() / ".rag_studio"
CONFIG_FILE = APP_DIR / "config.json"
RAG_REGISTRY_FILE = APP_DIR / "rag_registry.json"
RAG_DATA_DIR = APP_DIR / "rag_data"

IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".bmp", ".tiff", ".tif", ".webp", ".gif"}
PDF_EXTS = {".pdf"}
DOC_EXTS = {".ppt", ".pptx", ".csv", ".xlsx", ".xls", ".txt", ".md", ".json"}
ALL_EXTS = IMAGE_EXTS | PDF_EXTS | DOC_EXTS

DEFAULT_CONFIG = {
    "ollama_base_url": "http://localhost:11434",
    "llm_model": "llama3.2",
    "vlm_model": "llama3.2-vision",
    "embedding_model": "nomic-embed-text",
    "embedding_dim": 768,
    "num_ctx": 32768,
    "parser": "docling",
    "query_mode": "hybrid",
}


def ensure_dirs():
    APP_DIR.mkdir(parents=True, exist_ok=True)
    RAG_DATA_DIR.mkdir(parents=True, exist_ok=True)


def load_config() -> dict:
    ensure_dirs()
    cfg = dict(DEFAULT_CONFIG)
    if CONFIG_FILE.exists():
        try:
            cfg.update(json.loads(CONFIG_FILE.read_text(encoding="utf-8")))
        except Exception:
            pass
    return cfg


def save_config(cfg: dict):
    ensure_dirs()
    CONFIG_FILE.write_text(json.dumps(cfg, ensure_ascii=False, indent=2), encoding="utf-8")


def load_registry() -> dict:
    ensure_dirs()
    if RAG_REGISTRY_FILE.exists():
        try:
            return json.loads(RAG_REGISTRY_FILE.read_text(encoding="utf-8"))
        except Exception:
            pass
    return {}


def save_registry(reg: dict):
    ensure_dirs()
    RAG_REGISTRY_FILE.write_text(json.dumps(reg, ensure_ascii=False, indent=2), encoding="utf-8")


def safe_dirname(name: str) -> str:
    s = re.sub(r"[^\w가-힣\-]", "_", name.strip())
    return s or "rag"


