# ----------------------------------------------------------------------------
# 작은 유틸들
# ----------------------------------------------------------------------------
def sha256_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def bytes_to_b64(data: bytes, notepad_style: bool = False, wrap: int = 76) -> str:
    """표준(한 줄) 또는 Notepad++/MIME 스타일(wrap자마다 줄바꿈) base64.

    notepad_style=True 면 RFC 2045 처럼 wrap(기본 76)자마다 개행을 넣어
    Notepad++ MIME Tools 등 다른 도구의 출력과 문자열까지 맞춘다.
    줄바꿈은 표현 차이일 뿐 디코딩 결과(데이터)는 표준과 동일하다.
    """
    raw_b64 = base64.b64encode(data).decode("ascii")
    if not notepad_style:
        return raw_b64
    w = max(1, int(wrap))
    return "\n".join(raw_b64[i:i + w] for i in range(0, len(raw_b64), w))


def b64_to_bytes(text: str) -> bytes:
    # data URL 접두( data:...;base64, ) 가 붙어 있으면 떼어낸다
    if "," in text and text.strip().lower().startswith("data:"):
        text = text.split(",", 1)[1]
    return base64.b64decode(text.strip(), validate=False)


def maybe_convert_legacy(src: Path, out_dir: Path) -> Path:
    """legacy .doc/.ppt/.xls 는 soffice(LibreOffice) headless 로 .docx/.pptx/.xlsx 변환 시도."""
    target = {".doc": "docx", ".ppt": "pptx", ".xls": "xlsx"}[src.suffix.lower()]
    soffice = shutil.which("soffice") or shutil.which("libreoffice")
    if not soffice:
        raise RuntimeError(
            f"'{src.suffix}' 는 docling 이 직접 못 읽어요. LibreOffice(soffice) 가 없어 자동 변환도 불가합니다. "
            f"먼저 .{target} 로 저장해 주세요."
        )
    import subprocess
    subprocess.run(
        [soffice, "--headless", "--convert-to", target, "--outdir", str(out_dir), str(src)],
        check=True, capture_output=True, timeout=120,
    )
    converted = out_dir / (src.stem + "." + target)
    if not converted.exists():
        raise RuntimeError(f"soffice 변환 결과를 찾지 못했어요: {converted}")
    return converted


def _build_standard(artifacts_path, do_ocr, gen_images, images_scale, use_gpu):
    """기본 파이프라인: DocLayNet 레이아웃 + TableFormer 표 모델."""
    opts = PdfPipelineOptions()
    opts.do_ocr = bool(do_ocr)
    opts.generate_picture_images = bool(gen_images)
    opts.generate_page_images = bool(gen_images)
    try:
        opts.images_scale = float(images_scale)
    except Exception:
        pass

    ap = (artifacts_path or "").strip()
    if ap:
        opts.artifacts_path = ap  # 사전 다운로드한 모델 경로 (air-gapped)

    if use_gpu and ACCEL_AVAILABLE:
        try:
            opts.accelerator_options = AcceleratorOptions(
                num_threads=8, device=AcceleratorDevice.CUDA
            )
        except Exception:
            pass

    return DocumentConverter(
        format_options={InputFormat.PDF: PdfFormatOption(pipeline_options=opts)}
    )


def _build_granite_ollama(ollama_url, model_name, images_scale, gen_images):
    """granite-docling VLM 파이프라인을 Ollama(OpenAI 호환 엔드포인트)로 구동.

    Ollama 는 /v1/chat/completions 를 노출하므로 ApiVlmOptions 로 가리킨다.
    granite-docling 출력은 DocTags 포맷이다.
    """
    if not VLM_AVAILABLE:
        raise RuntimeError(f"VLM 파이프라인 임포트 실패: {VLM_IMPORT_ERROR} (docling 버전 확인)")

    base = (ollama_url or "http://localhost:11434").rstrip("/")
    if not base.endswith("/v1/chat/completions"):
        base = base + "/v1/chat/completions"

    # 로컬 Ollama 는 회사 프록시를 타면 안 된다 → NO_PROXY 보강
    import os
    host = base.split("//", 1)[-1].split("/", 1)[0].split(":", 1)[0]
    for var in ("NO_PROXY", "no_proxy"):
        cur = os.environ.get(var, "")
        if host not in cur:
            os.environ[var] = (cur + "," if cur else "") + host + ",localhost,127.0.0.1"

    api_opts = ApiVlmOptions(
        url=base,
        params={"model": model_name or "ibm/granite-docling"},
        prompt="Convert this page to docling.",
        timeout=180,
        scale=float(images_scale) if images_scale else 2.0,
        response_format=ResponseFormat.DOCTAGS,
    )

    vlm_opts = VlmPipelineOptions(enable_remote_services=True)
    vlm_opts.vlm_options = api_opts
    try:
        vlm_opts.generate_picture_images = bool(gen_images)
    except Exception:
        pass

    pdf_fmt = PdfFormatOption(pipeline_cls=VlmPipeline, pipeline_options=vlm_opts)
    fmts = {InputFormat.PDF: pdf_fmt}
    try:  # 이미지 입력도 VLM 으로
        fmts[InputFormat.IMAGE] = pdf_fmt
    except Exception:
        pass
    return DocumentConverter(format_options=fmts)


def build_converter(engine, artifacts_path, do_ocr, gen_images, images_scale,
                    use_gpu, ollama_url, model_name):
    """엔진 선택에 따라 컨버터 생성. DOCX/PPTX 등은 두 경우 모두 native 파서가 처리."""
    if engine and engine.startswith("granite"):
        return _build_granite_ollama(ollama_url, model_name, images_scale, gen_images)
    return _build_standard(artifacts_path, do_ocr, gen_images, images_scale, use_gpu)


# ----------------------------------------------------------------------------
# 핵심 변환 한 건
# ----------------------------------------------------------------------------
def process_one(src_path: Path, converter, out_dir: Path,
                roundtrip_b64: bool, embed_b64: bool) -> dict:
    """파일 1개 → DoclingDocument. 결과 메타 dict 반환."""
    orig_raw = src_path.read_bytes()      # 사용자가 올린 '진짜 원본'
    orig_sha = sha256_bytes(orig_raw)
    orig_size = len(orig_raw)

    log_lines = [f"· 원본: {src_path.name} ({orig_size:,} bytes)  sha256={orig_sha[:12]}…"]

    # legacy 포맷 변환 (.doc/.ppt/.xls → docx/pptx/xlsx). work_raw = docling 에 먹일 바이트
    work_src = src_path
    work_raw = orig_raw
    converted = False
    if src_path.suffix.lower() in LEGACY_EXT:
        work_src = maybe_convert_legacy(src_path, out_dir)
        work_raw = work_src.read_bytes()
        converted = True
        log_lines.append(f"· legacy 변환 → {work_src.name} ({len(work_raw):,} bytes)")

    # (선택) base64 round-trip 무결성 검증 — docling 에 먹일 바이트 기준
    if roundtrip_b64:
        restored = b64_to_bytes(bytes_to_b64(work_raw))
        ok = sha256_bytes(restored) == sha256_bytes(work_raw)
        tgt = "변환본" if converted else "원본"
        log_lines.append(f"· base64 round-trip 무결성({tgt}): {'OK ✔' if ok else '불일치 ✗'}")
        if not ok:
            raise RuntimeError("base64 round-trip 해시 불일치 — 인코딩 손상")
        decoded = restored
    else:
        decoded = work_raw

    # docling 변환 (메모리 스트림으로 직접 — 임시 파일 불필요)
    stream = DocumentStream(name=work_src.name, stream=io.BytesIO(decoded))
    result = converter.convert(stream)
    doc = result.document

    stem = src_path.stem
    case_dir = out_dir / stem
    case_dir.mkdir(parents=True, exist_ok=True)

    # 1) 정본: DoclingDocument JSON
    json_path = case_dir / f"{stem}.docling.json"
    try:
        doc.save_as_json(json_path)
    except Exception:
        json_path.write_text(json.dumps(doc.export_to_dict(), ensure_ascii=False, indent=2),
                             encoding="utf-8")

    # 2) 투입용: Markdown + REFERENCED 이미지 사이드카 (인라인 base64 금지)
    md_path = case_dir / f"{stem}.md"
    try:
        doc.save_as_markdown(md_path, image_mode=ImageRefMode.REFERENCED)
    except Exception:
        md_path.write_text(doc.export_to_markdown(), encoding="utf-8")
    md_text = md_path.read_text(encoding="utf-8")

    # 3) provenance 봉투(JSON): 원본 메타 + (선택)원본 base64 + docling dict
    src_meta = {
        "filename": src_path.name,
        "format": src_path.suffix.lower().lstrip("."),
        "sha256": orig_sha,
        "size_bytes": orig_size,
        "ingested_at": datetime.now().isoformat(timespec="seconds"),
        "base64": bytes_to_b64(orig_raw) if embed_b64 else None,  # 진짜 원본 기준
    }
    if converted:
        # legacy → docling 입력은 변환본이므로 그 메타도 함께 기록
        src_meta["converted_to"] = {
            "filename": work_src.name,
            "format": work_src.suffix.lower().lstrip("."),
            "sha256": sha256_bytes(work_raw),
            "size_bytes": len(work_raw),
        }
    envelope = {"source": src_meta, "docling": doc.export_to_dict()}
    env_path = case_dir / f"{stem}.envelope.json"
    env_path.write_text(json.dumps(envelope, ensure_ascii=False, indent=2), encoding="utf-8")

    # 추출된 그림 파일 목록 (사이드카)
    imgs = sorted([p for p in case_dir.rglob("*")
                   if p.suffix.lower() in {".png", ".jpg", ".jpeg"}])

    log_lines.append(f"· 그림 사이드카: {len(imgs)}개")
    log_lines.append(f"· 출력: {case_dir}")

    return {
        "name": src_path.name,
        "case_dir": case_dir,
        "json_path": json_path,
        "md_path": md_path,
        "env_path": env_path,
        "md_text": md_text,
        "images": [str(p) for p in imgs],
        "log": "\n".join(log_lines),
        "n_pages": getattr(doc, "num_pages", lambda: None)() if callable(getattr(doc, "num_pages", None)) else None,
    }


def run_pipeline(files, engine, artifacts_path, do_ocr, gen_images, images_scale,
                 use_gpu, ollama_url, model_name, roundtrip_b64, embed_b64):
    """Gradio 핸들러: 여러 파일 처리 → 미리보기 + zip 다운로드."""
    if not DOCLING_AVAILABLE:
        return (f"❌ docling 임포트 실패: {DOCLING_IMPORT_ERROR}\n"
                f"   rag311 환경에서 실행했는지 확인하세요.", "", [], None, gr.update(choices=[], value=None))
    if not files:
        return "파일을 올려주세요.", "", [], None, gr.update(choices=[], value=None)

    run_dir = WORK_ROOT / datetime.now().strftime("run_%Y%m%d_%H%M%S")
    run_dir.mkdir(parents=True, exist_ok=True)

    try:
        converter = build_converter(engine, artifacts_path, do_ocr, gen_images,
                                    images_scale, use_gpu, ollama_url, model_name)
    except Exception as e:
        return f"❌ 컨버터 생성 실패: {e}\n{traceback.format_exc()}", "", [], None, gr.update(choices=[], value=None)

    results, logs = [], []
    for f in files:
        src = Path(f.name if hasattr(f, "name") else f)
        ext = src.suffix.lower()
        if ext not in SUPPORTED_EXT and ext not in LEGACY_EXT:
            logs.append(f"⏭  건너뜀(미지원 {ext}): {src.name}")
            continue
        try:
            r = process_one(src, converter, run_dir, roundtrip_b64, embed_b64)
            results.append(r)
            logs.append(f"✅ {r['name']}\n{r['log']}")
        except Exception as e:
            logs.append(f"❌ {src.name}\n   {type(e).__name__}: {e}")

    if not results:
        return "\n\n".join(logs) or "처리된 파일이 없습니다.", "", [], None, gr.update(choices=[], value=None)

    # 전체 zip
    zip_path = run_dir.parent / f"{run_dir.name}.zip"
    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
        for p in run_dir.rglob("*"):
            if p.is_file():
                zf.write(p, p.relative_to(run_dir.parent))

    first = results[0]
    choices = [r["name"] for r in results]
    run_pipeline._cache = {r["name"]: r for r in results}  # 미리보기 전환용

    return (
        "\n\n".join(logs),
        first["md_text"],
        first["images"],
        str(zip_path),
        gr.update(choices=choices, value=first["name"]),
    )


def switch_preview(name):
    cache = getattr(run_pipeline, "_cache", {})
    r = cache.get(name)
    if not r:
        return "", []
    return r["md_text"], r["images"]


# ----------------------------------------------------------------------------
# base64 유틸 탭 핸들러
# ----------------------------------------------------------------------------
def encode_file(f, notepad_style, wrap):
    if not f:
        return "", "", None
    data = Path(f.name).read_bytes()
    b64 = bytes_to_b64(data, notepad_style=bool(notepad_style), wrap=int(wrap))
    style = f"Notepad++/MIME ({int(wrap)}자 줄바꿈)" if notepad_style else "표준 (한 줄)"
    info = (f"{Path(f.name).name} · {len(data):,} bytes · "
            f"sha256={sha256_bytes(data)[:16]}… · 스타일: {style} · base64 {len(b64):,}자")
    # 전체 base64 를 .b64 파일로 저장(다른 도구 출력과 바이너리 diff 비교용)
    out = WORK_ROOT / (Path(f.name).stem + (".np.b64" if notepad_style else ".b64"))
    out.write_text(b64, encoding="ascii", newline="\n")
    preview = b64 if len(b64) <= 4000 else b64[:4000] + f"\n… (총 {len(b64):,}자, 미리보기 절단)"
    return info, preview, str(out)


def decode_b64(text, filename):
    if not text.strip():
        return "내용이 비었습니다.", None
    try:
        data = b64_to_bytes(text)
    except Exception as e:
        return f"디코드 실패: {e}", None
    out = WORK_ROOT / (filename.strip() or "restored.bin")
    out.write_bytes(data)
    info = f"복원: {out.name} · {len(data):,} bytes · sha256={sha256_bytes(data)[:16]}…"
    return info, str(out)


