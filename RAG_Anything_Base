"""

INSTALL_GUIDE_MD = """
## 📦 패키지 설치 가이드

### 1. 가상환경 (권장 — 의존성 충돌 방지)
```bash
python -m venv venv_rag
# Windows
venv_rag\\Scripts\\activate
# Linux/macOS
source venv_rag/bin/activate
```

### 2. 핵심 패키지
```bash
pip install gradio raganything "raganything[all]"
```

### 3. 문서 파서 (택1)
```bash
# Docling — Office/HTML 강함, 설치 쉬움 (추천)
pip install "docling[all]"

# MinerU — PDF/OCR 강함, GPU 가속
pip install magic-pdf[full]
```

### 4. Ollama 모델
```bash
# Ollama 설치: https://ollama.com

# LLM (텍스트 생성) — 택1
ollama pull llama3.2          # 3B, 빠름
ollama pull qwen2.5           # 7B, 한국어 우수

# VLM (이미지 처리) — 이미지 RAG 시
ollama pull llama3.2-vision

# 임베딩 (필수)
ollama pull nomic-embed-text  # 768차원 (권장)
ollama pull bge-m3            # 1024차원, 다국어
```

### 5. 실행
```bash
python rag_studio_gradio.py
# → http://localhost:7860
```

### 6. 에어갭(오프라인) 환경
```bash
# 온라인 PC에서 다운로드
pip download gradio "raganything[all]" "docling[all]" -d ./pkgs
# 오프라인 PC에서 설치
pip install --no-index --find-links=./pkgs gradio raganything docling
```
Ollama 모델 파일: `~/.ollama/models/` → 복사 이동 가능

### 💡 하드웨어 권장
| 작업 | GPU | RAM |
|---|---|---|
| 인덱싱 (구축) | VRAM 8GB+ | 16GB+ |
| Q&A (이용) | CPU 가능* | 8GB+ |

*Q&A 시 LLM은 Ollama 서버 URL로 원격 연결 권장

### ⚠ 의존성 충돌 경고가 떠도
`raganything`, `lightrag`, `gradio` import만 정상이면 동작합니다:
```bash
python -c "import raganything, lightrag, gradio; print('OK')"
```
"""


def build_app():
    cfg = load_config()

    with gr.Blocks(title="RAG Studio", css=CUSTOM_CSS) as demo:
        # 상태 (설정값을 세션에 보관)
        cfg_state = gr.State(cfg)

        gr.HTML(
            "<div id='app-header'>"
            "<h1>◈ RAG Studio</h1>"
            "<p>RAG-Anything · Ollama · 멀티모달 로컬 RAG 관리 도구</p>"
            "</div>"
        )

        with gr.Tabs():
            # ════════════ TAB 1: RAG 관리 ════════════
            with gr.Tab("📚 RAG 관리"):
                with gr.Row():
                    # 왼쪽: RAG 생성/선택
                    with gr.Column(scale=1):
                        gr.Markdown("### RAG 시스템")
                        manage_dropdown = gr.Dropdown(
                            label="RAG 선택",
                            choices=get_rag_choices(),
                            interactive=True,
                        )
                        with gr.Accordion("➕ 새 RAG 만들기", open=True):
                            new_name = gr.Textbox(
                                label="이름",
                                placeholder="예: 연구논문_2024, EDS_데이터셋")
                            new_desc = gr.Textbox(
                                label="설명 (선택)",
                                placeholder="용도 / 내용 간단 설명")
                            create_btn = gr.Button("만들기", variant="primary")
                        delete_btn = gr.Button("선택한 RAG 삭제", variant="stop")
                        manage_status = gr.Markdown("")

                    # 오른쪽: 파일 추가 + 인덱싱
                    with gr.Column(scale=2):
                        gr.Markdown("### 파일 추가 (폴더 경로 입력 — 하위 폴더 재귀 탐색)")
                        folder_img = gr.Textbox(
                            label="🖼 이미지 폴더",
                            placeholder="예: D:/data/images  (jpg, png, tiff, webp ...)")
                        folder_pdf = gr.Textbox(
                            label="📄 PDF 폴더",
                            placeholder="예: D:/data/papers  (pdf)")
                        folder_doc = gr.Textbox(
                            label="📁 문서 폴더",
                            placeholder="예: D:/data/docs  (ppt, pptx, csv, xlsx, txt, md, json)")

                        with gr.Row():
                            preview_btn = gr.Button("🔍 파일 미리보기")
                            index_btn = gr.Button("⚡ 인덱싱 시작", variant="primary")

                        preview_md = gr.Markdown("")
                        files_state = gr.State([])

                        index_log = gr.Textbox(
                            label="처리 로그",
                            lines=10,
                            interactive=False,
                            elem_classes="status-box",
                        )

                gr.Markdown("### 등록된 RAG 목록")
                rag_table = gr.Dataframe(
                    headers=["이름", "설명", "파일 수", "생성일", "저장 경로"],
                    value=registry_to_table(),
                    interactive=False,
                    wrap=True,
                )

            # ════════════ TAB 2: Q&A ════════════
            with gr.Tab("💬 Q&A"):
                with gr.Row():
                    qa_dropdown = gr.Dropdown(
                        label="RAG 선택",
                        choices=get_rag_choices(),
                        scale=2,
                        interactive=True,
                    )
                    qa_mode = gr.Dropdown(
                        label="검색 모드",
                        choices=["hybrid", "local", "global", "naive"],
                        value="hybrid",
                        scale=1,
                        info="hybrid=그래프+벡터(권장)",
                    )
                    qa_refresh = gr.Button("↻ 목록 갱신", scale=1)

                chatbot = make_chatbot(
                    label="대화",
                    height=440,
                )
                with gr.Row():
                    question_box = gr.Textbox(
                        label="질문",
                        placeholder="질문을 입력하고 Enter (Shift+Enter 줄바꿈)",
                        lines=2,
                        scale=5,
                    )
                    ask_btn = gr.Button("전송 ▶", variant="primary", scale=1)
                clear_btn = gr.Button("대화 초기화")

            # ════════════ TAB 3: 설정 ════════════
            with gr.Tab("⚙ 설정"):
                gr.Markdown("### Ollama 연결")
                with gr.Row():
                    set_url = gr.Textbox(
                        label="Ollama URL",
                        value=cfg["ollama_base_url"], scale=3)
                    test_btn = gr.Button("연결 테스트", scale=1)
                test_status = gr.Markdown("")

                gr.Markdown("### 모델 선택")
                fetch_btn = gr.Button("↻ Ollama 모델 목록 가져오기")
                _models = fetch_ollama_models(cfg["ollama_base_url"])
                with gr.Row():
                    set_llm = gr.Dropdown(
                        label="LLM (텍스트)", allow_custom_value=True,
                        choices=_models or [cfg["llm_model"]], value=cfg["llm_model"])
                    set_vlm = gr.Dropdown(
                        label="VLM (이미지)", allow_custom_value=True,
                        choices=_models or [cfg["vlm_model"]], value=cfg["vlm_model"])
                    set_embed = gr.Dropdown(
                        label="임베딩", allow_custom_value=True,
                        choices=_models or [cfg["embedding_model"]], value=cfg["embedding_model"])

                gr.Markdown("### 임베딩 / 파서 설정")
                with gr.Row():
                    set_dim = gr.Number(
                        label="임베딩 차원", value=cfg["embedding_dim"], precision=0,
                        info="nomic=768, mxbai=1024, bge-m3=1024")
                    set_ctx = gr.Number(
                        label="컨텍스트 크기 (num_ctx)", value=cfg["num_ctx"], precision=0,
                        info="최소 32768 권장")
                    set_parser = gr.Dropdown(
                        label="문서 파서",
                        choices=["docling", "mineru", "paddleocr"],
                        value=cfg["parser"],
                        info="docling=Office, mineru=PDF/OCR")

                save_btn = gr.Button("설정 저장", variant="primary")
                save_status = gr.Markdown("")

            # ════════════ TAB 4: 설치 가이드 ════════════
            with gr.Tab("📖 설치 가이드"):
                gr.Markdown(INSTALL_GUIDE_MD)

        # ──────────────── 이벤트 연결 ────────────────
        # RAG 관리
        create_btn.click(
            create_rag,
            inputs=[new_name, new_desc],
            outputs=[manage_dropdown, manage_status, qa_dropdown, rag_table],
        )
        delete_btn.click(
            delete_rag,
            inputs=[manage_dropdown],
            outputs=[manage_dropdown, manage_status, qa_dropdown, rag_table],
        )
        preview_btn.click(
            preview_folder,
            inputs=[folder_img, folder_pdf, folder_doc],
            outputs=[preview_md, files_state],
        )
        index_btn.click(
            run_indexing,
            inputs=[manage_dropdown, folder_img, folder_pdf, folder_doc, cfg_state],
            outputs=[index_log],
        ).then(
            lambda: registry_to_table(), outputs=[rag_table]
        )

        # Q&A
        ask_btn.click(
            answer_question,
            inputs=[question_box, qa_dropdown, qa_mode, chatbot, cfg_state],
            outputs=[chatbot, question_box],
        )
        question_box.submit(
            answer_question,
            inputs=[question_box, qa_dropdown, qa_mode, chatbot, cfg_state],
            outputs=[chatbot, question_box],
        )
        clear_btn.click(lambda: [], outputs=[chatbot])
        qa_refresh.click(
            lambda: gr.update(choices=get_rag_choices()),
            outputs=[qa_dropdown],
        )

        # 설정
        test_btn.click(lambda u: test_ollama(u), inputs=[set_url], outputs=[test_status])
        fetch_btn.click(
            refresh_models,
            inputs=[set_url],
            outputs=[set_llm, set_vlm, set_embed, save_status],
        )
        save_btn.click(
            save_settings,
            inputs=[set_url, set_llm, set_vlm, set_embed,
                    set_dim, set_ctx, set_parser, cfg_state],
            outputs=[cfg_state, save_status],
        )

    return demo


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description="RAG Studio")
    parser.add_argument("--host", default="127.0.0.1",
                        help="서버 호스트 (기본: 127.0.0.1 / 내부망 공유: 0.0.0.0)")
    parser.add_argument("--port", type=int, default=7860,
                        help="서버 포트 (기본: 7860)")
    parser.add_argument("--share", action="store_true",
                        help="Gradio 공개 링크 생성 (외부망 필요)")
    args = parser.parse_args()

    ensure_dirs()
    app = build_app()

    print(f"\n✅ RAG Studio 시작")
    print(f"   브라우저에서 열기 → http://{args.host}:{args.port}")
    print(f"   종료: Ctrl+C\n")

    app.launch(
        server_name=args.host,
        server_port=args.port,
        show_error=True,
        inbrowser=False,   # 사내 보안망에서 자동 브라우저 오픈 비활성화
        share=args.share,
    )
