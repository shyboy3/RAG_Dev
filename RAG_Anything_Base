        url = self.url_edit.text().strip()
        self.fetch_worker = OllamaModelsWorker(url)
        self.fetch_worker.result.connect(self._on_models_fetched)
        self.fetch_worker.error.connect(lambda e: QMessageBox.warning(
            self, "오류", f"모델 목록 가져오기 실패:\n{e}"))
        self.fetch_worker.start()

    def _on_models_fetched(self, models):
        for combo in [self.llm_combo, self.vlm_combo, self.embed_combo]:
            current = combo.currentText()
            combo.clear()
            combo.addItems(models)
            if current in models:
                combo.setCurrentText(current)
        QMessageBox.information(self, "완료", f"{len(models)}개 모델을 가져왔습니다.")

    def _save(self):
        self.cfg.update({
            "ollama_base_url": self.url_edit.text().strip(),
            "llm_model": self.llm_combo.currentText().strip(),
            "vlm_model": self.vlm_combo.currentText().strip(),
            "embedding_model": self.embed_combo.currentText().strip(),
            "embedding_dim": self.embed_dim_spin.value(),
            "num_ctx": self.ctx_spin.value(),
            "parser": self.parser_combo.currentText(),
        })
        save_config(self.cfg)
        QMessageBox.information(self, "저장", "설정이 저장되었습니다.")

    def get_cfg(self):
        return self.cfg


