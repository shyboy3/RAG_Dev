class NewRAGDialog(QDialog):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setWindowTitle("새 RAG 시스템 만들기")
        self.setMinimumWidth(480)
        self.setStyleSheet(STYLESHEET)
        self._build_ui()

    def _build_ui(self):
        layout = QVBoxLayout(self)
        layout.setSpacing(14)
        layout.setContentsMargins(24, 24, 24, 20)

        title = QLabel("새 RAG 시스템")
        title.setFont(QFont("Segoe UI", 15, QFont.Weight.Bold))
        title.setStyleSheet(f"color: {ACCENT}; margin-bottom: 6px;")
        layout.addWidget(title)

        # RAG 이름
        layout.addWidget(QLabel("RAG 이름 *"))
        self.name_edit = QLineEdit()
        self.name_edit.setPlaceholderText("예: 연구논문_2024, EDS_데이터셋, 사내규정")
        layout.addWidget(self.name_edit)

        # 설명
        layout.addWidget(QLabel("설명 (선택)"))
        self.desc_edit = QLineEdit()
        self.desc_edit.setPlaceholderText("이 RAG의 용도나 내용을 간단히 설명")
        layout.addWidget(self.desc_edit)

        # 저장 경로
        layout.addWidget(QLabel("저장 경로 *"))
        path_row = QHBoxLayout()
        self.path_edit = QLineEdit()
        default_path = str(APP_DIR / "rag_data" / "new_rag")
        self.path_edit.setPlaceholderText(default_path)
        path_row.addWidget(self.path_edit)
        browse_btn = QPushButton("찾아보기")
        browse_btn.setFixedWidth(80)
        browse_btn.clicked.connect(self._browse_path)
        path_row.addWidget(browse_btn)
        layout.addLayout(path_row)

        # 버튼
        btn_box = QDialogButtonBox(
            QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel
        )
        btn_box.accepted.connect(self._validate_and_accept)
        btn_box.rejected.connect(self.reject)
        btn_box.button(QDialogButtonBox.StandardButton.Ok).setText("만들기")
        btn_box.button(QDialogButtonBox.StandardButton.Ok).setObjectName("primary")
        layout.addWidget(btn_box)

    def _browse_path(self):
        d = QFileDialog.getExistingDirectory(self, "저장 폴더 선택")
        if d:
            name = self.name_edit.text().strip() or "new_rag"
            self.path_edit.setText(str(Path(d) / name))

    def _validate_and_accept(self):
        name = self.name_edit.text().strip()
        if not name:
            QMessageBox.warning(self, "입력 오류", "RAG 이름을 입력하세요.")
            return
        if not self.path_edit.text().strip():
            suggested = str(APP_DIR / "rag_data" / name)
            self.path_edit.setText(suggested)
        self.accept()

    def get_values(self):
        name = self.name_edit.text().strip()
        path = self.path_edit.text().strip() or str(APP_DIR / "rag_data" / name)
        desc = self.desc_edit.text().strip()
        return name, path, desc


